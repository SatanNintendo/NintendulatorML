# NintendulatorML Language File - Japanese
# Format: KEY=Value  |  # = comment  |  \n = newline in value

[Info]
Language=日本語 / Japanese
Author=Community
Version=1.0

[Strings]


# === メインメニュー — 最上位レベル ===
MENU_FILE=&ファイル
MENU_CPU=&CPU
MENU_PPU=&PPU
MENU_SOUND=&サウンド
MENU_INPUT=&入力
MENU_DEBUG=&デバッグ
MENU_MISC=&その他
MENU_LANGUAGE=&言語
MENU_HELP=&ヘルプ

# === ファイルサブメニュー ===
MENU_FILE_OPEN=&ROMを開く...
MENU_FILE_CLOSE=&閉じる
MENU_FILE_RECENT=最近の&ファイル
MENU_FILE_RECENT_CLEAR=最近のファイルをクリア(&C)
