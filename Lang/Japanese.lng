MENU_FILE_AUTORUN=自動実行(&A)
MENU_FILE_BROWSESAVES=セーブファイルを閲覧(&B)
MENU_FILE_EXIT=終了(&X)

# === CPUサブメニュー ===
MENU_NES_RUN=実行(&R)\tF2
MENU_NES_PAUSE=ステップ(&S)\tShift+F2
MENU_NES_STOP=停止(&T)\tF3
MENU_NES_RESET=ソフトリセット(&F)\tF4
MENU_NES_POWER=ハードリセット(&H)\tShift+F4
